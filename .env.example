# Sisyphus Academica — Configuration
# Copy to .env and fill in
#
# Required:
#   - At least one literature API key for paper search
#   - A model provider configured in config/agent-config.json
#
# Optional but recommended:
#   - Voice sample for author voice calibration
#   - CrossRef polite pool email for higher rate limits

# === LITERATURE SEARCH APIs ===

# Semantic Scholar API key (free, increases rate limit from 100 to 1000 req/min)
# Get: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef polite pool email (increases rate limit significantly)
# Use your institutional email:
CROSSREF_EMAIL=

# === HUMANIZER ===

# Path to Humanizer skill (default: ~/.config/opencode/skills/humanizer)
# Installed automatically by install.sh
HUMANIZER_PATH=${HOME}/.config/opencode/skills/humanizer

# === VENUE ===

# Default venue target
# Options: neurips, icml, iclr, acl, nature, arxiv
DEFAULT_VENUE=arxiv

# === VOICE ===

# Path to voice calibration sample (optional, recommended)
# Provide 2-3 paragraphs of your published writing in a text file
# The Research Director will calibrate all writer agents to match your voice
VOICE_SAMPLE_PATH=${SISYPHUS_ACADEMICA_DIR:-.}/data/voice-profile/sample.txt

# === LLM PROVIDER (optional override) ===

# By default, models are configured in config/agent-config.json
# Set this to override the provider for all agents at once
# LLM_PROVIDER=anthropic/claude-opus-4
